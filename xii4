<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Sistem Galeri Terstruktur</title>
    <style>
        :root {
            --background: #0f172a;
            --surface: #1e293b;
            --text: #f8fafc;
            --text-muted: #94a3b8;
            --border: #334155;
            --folder-color: #f59e0b;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: sans-serif; }
        body { background-color: var(--background); color: var(--text); padding: 16px; min-height: 100vh; }
        .container { width: 100%; max-width: 800px; margin: 0 auto; }
        
        header { text-align: center; padding: 20px 0; margin-bottom: 24px; border-bottom: 1px solid var(--border); }
        header h1 { font-size: 24px; color: #818cf8; }
        
        .loading { text-align: center; padding: 40px; color: var(--text-muted); font-style: italic; }

        /* Gaya Struktur Pohon Folder */
        .folder-node { margin-left: 15px; margin-top: 8px; }
        
        .folder-header {
            background-color: var(--surface);
            padding: 12px 16px;
            border-radius: 8px;
            border: 1px solid var(--border);
            cursor: pointer;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
            user-select: none;
        }
        
        .folder-header::before { content: "📁"; color: var(--folder-color); }
        .folder-node.open > .folder-header::before { content: "📂"; }
        
        .folder-content { display: none; padding-left: 10px; border-left: 2px dashed var(--border); margin-top: 4px; }
        .folder-node.open > .folder-content { display: block; }

        /* Grid khusus untuk file di dalam folder */
        .file-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin-top: 8px;
            margin-bottom: 8px;
        }
        @media (min-width: 600px) { .file-grid { grid-template-columns: repeat(3, 1fr); } }

        /* Kartu Elemen File */
        .file-card {
            background: #111827;
            border: 1px solid var(--border);
            border-radius: 6px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            text-decoration: none;
            color: inherit;
        }

        .img-container { width: 100%; aspect-ratio: 1/1; background: #000; }
        .img-container img { width: 100%; height: 100%; object-fit: cover; }

        /* Tampilan untuk file Non-Gambar (PDF, dll) */
        .non-img-container {
            width: 100%;
            aspect-ratio: 1/1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: #1e293b;
            font-size: 32px;
        }
        .non-img-label { font-size: 11px; color: var(--text-muted); margin-top: 5px; font-weight: bold; text-transform: uppercase; }

        .file-info { padding: 8px; font-size: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; text-align: center; }
    </style>
</head>
<body>

    <div class="container">
        <header>
            <h1>SISTEM FILE & FOLDER KELAS</h1>
            <p>Klik pada folder untuk membuka atau menutup isinya</p>
        </header>

        <div id="loader" class="loading">Sedang memetakan seluruh struktur folder... Mohon tunggu ☕</div>

        <div id="treeContainer"></div>
    </div>

    <script>
        // TEMPELKAN URL WEB APP GOOGLE APPS SCRIPT YANG BARU DI SINI
        const scriptUrl = "https://script.google.com/macros/s/AKfycbxG9vhtpRrFkeR7EgtW7odNcdh2TlxLfE9FZ55V05UuBvf0_F-rQy6xH02h_DQQIqBX/exec";

        async function init() {
            try {
                const response = await fetch(scriptUrl);
                const data = await response.json();
                
                document.getElementById('loader').style.display = 'none';
                
                const container = document.getElementById('treeContainer');
                // Bangun struktur data mulai dari root utama
                container.appendChild(buildTreeDOM(data));
            } catch (err) {
                document.getElementById('loader').innerText = "Gagal memuat struktur data folder.";
                console.error(err);
            }
        }

        function buildTreeDOM(node) {
            const folderDiv = document.createElement('div');
            folderDiv.className = 'folder-node';
            
            // Membuat Bar Judul Folder
            const header = document.createElement('div');
            header.className = 'folder-header';
            header.innerText = node.name;
            header.onclick = (e) => {
                e.stopPropagation();
                folderDiv.classList.toggle('open');
            };
            folderDiv.appendChild(header);
            
            // Membuat Wadah Isi Folder
            const contentDiv = document.createElement('div');
            contentDiv.className = 'folder-content';
            
            const fileGrid = document.createElement('div');
            fileGrid.className = 'file-grid';
            
            let hasFiles = false;

            // Memisahkan children: mana yang folder, mana yang file
            node.children.forEach(child => {
                if (child.type === 'folder') {
                    // Jika isi di dalamnya adalah folder lagi, panggil fungsi ini lagi (rekursif)
                    contentDiv.appendChild(buildTreeDOM(child));
                } else {
                    hasFiles = true;
                    const fileCard = document.createElement('a');
                    fileCard.className = 'file-card';
                    fileCard.href = `https://drive.google.com/open?id=${child.id}`;
                    fileCard.target = '_blank';

                    if (child.type === 'image') {
                        // Jika gambar, gunakan s0 agar kualitasnya asli 100% tanpa kompresi
                        fileCard.innerHTML = `
                            <div class="img-container">
                                <img src="https://lh3.googleusercontent.com/d/${child.id}=s0" alt="${child.name}">
                            </div>
                            <div class="file-info">${child.name}</div>
                        `;
                    } else {
                        // Jika file dokumen, PDF atau lainnya, tampilkan ikon representatif
                        let icon = "📄";
                        let label = "File";
                        if (child.type === 'pdf') { icon = "📕"; label = "PDF"; }
                        if (child.type === 'video') { icon = "🎬"; label = "Video"; }
                        
                        fileCard.innerHTML = `
                            <div class="non-img-container">
                                <div>${icon}</div>
                                <div class="non-img-label">${label}</div>
                            </div>
                            <div class="file-info">${child.name}</div>
                        `;
                    }
                    fileGrid.appendChild(fileCard);
                }
            });

            if (hasFiles) {
                contentDiv.insertBefore(fileGrid, contentDiv.firstChild);
            }
            
            folderDiv.appendChild(contentDiv);
            return folderDiv;
        }

        // Jalankan program
        init();
    </script>
</body>
</html>
